# ===== REQUIRED =====

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Telegram Bot Tokens (get from @BotFather)
TELEGRAM_BOT_TOKEN="YOUR_USER_BOT_TOKEN"
ADMIN_BOT_TOKEN="YOUR_ADMIN_BOT_TOKEN"

# Admin bot receives all notifications as fallback
ADMIN_CHAT_ID="YOUR_TELEGRAM_USER_ID"

# Bot username (without @)
TELEGRAM_BOT_USERNAME="YOUR_BOT_USERNAME"

# App URL (your deployed domain)
HOST_URL="https://your-domain.com"

# Admin panel password
ADMIN_PASSWORD="CHANGE_THIS_TO_A_STRONG_PASSWORD"

# ===== OPTIONAL =====

# Gemini AI API (optional feature)
GEMINI_API_KEY=""
